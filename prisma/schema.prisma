generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ShippingStatus {
  PENDING
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryMovementType {
  CREATED
  ADJUSTMENT
  ORDER_DEDUCTION
}

enum Division {
  Cauchos
  Import
  Innovation
  Energy
  Plastic
}

model Product {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  sku                   String?             @unique
  oemReference          String?
  alternativeReferences String[]            @default([])
  category              String
  name                  String
  brand                 String
  division              Division            @default(Cauchos)
  price                 Int
  previousPrice         Int
  displayPriceOverride   String?
  displaySecondaryLabel  String?
  stock                 Int                 @default(12)
  minimumStock          Int                 @default(3)
  image                 String
  galleryImages         String[]            @default([])
  availability          String
  description           String
  application           String?
  compatibility         String[]            @default([])
  warranty              String?
  featured              Boolean             @default(false)
  active                Boolean             @default(true)
  inventoryMovements    InventoryMovement[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model User {
  id           String    @id @default(cuid())
  fullName     String
  company      String?
  email        String    @unique
  phone        String?
  department   String?
  city         String?
  addressLine1 String?
  addressLine2 String?
  passwordHash String
  role         UserRole  @default(CUSTOMER)
  division     Division?
  cartItems    CartItem[]
  orders       Order[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  name      String
  price     String
  image     String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  shippingStatus ShippingStatus @default(PENDING)
  customerName  String
  customerEmail String
  customerPhone String
  company       String?
  department    String
  city          String
  addressLine1  String
  addressLine2  String?
  notes         String?
  carrier       String?
  trackingNumber String?
  adminNotes    String?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  subtotal      Int
  totalItems    Int
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  image     String
  unitPrice Int
  quantity  Int
  lineTotal Int
  createdAt DateTime @default(now())
}

model InventoryMovement {
  id         String                @id @default(cuid())
  productId  String
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       InventoryMovementType
  quantity   Int
  stockAfter Int
  note       String?
  createdAt  DateTime              @default(now())
}

model SiteImage {
  key       String   @id
  url       String
  updatedAt DateTime @updatedAt
}
